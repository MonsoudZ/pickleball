<%= turbo_frame_tag "calendar" do %>
  <% previous_month = (month - 1.month).strftime("%Y-%m") %>
  <% next_month = (month + 1.month).strftime("%Y-%m") %>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-4 flex items-center justify-between gap-2">
      <%= link_to "< Previous", calendar_path(month: previous_month), data: { turbo_frame: "calendar" }, class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100" %>
      <h2 class="text-lg font-black text-slate-900"><%= month.strftime("%B %Y") %></h2>
      <%= link_to "Next >", calendar_path(month: next_month), data: { turbo_frame: "calendar" }, class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100" %>
    </div>

    <div class="overflow-x-auto pb-1">
      <div class="min-w-[760px] lg:min-w-[980px]">
        <div class="mb-2 grid grid-cols-7 gap-2">
          <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |day_name| %>
            <span class="text-center text-xs font-bold uppercase tracking-wide text-slate-500"><%= day_name %></span>
          <% end %>
        </div>

        <div class="grid grid-cols-7 gap-2">
          <% calendar_days_for(month).each do |day| %>
            <% day_sessions = sessions_by_day.fetch(day, []) %>
            <% day_classes = day.month == month.month ? "bg-white" : "bg-slate-100/80" %>

            <article class="min-h-32 rounded-lg border border-slate-200 p-2.5 sm:min-h-40 <%= day_classes %>">
              <header class="mb-2 flex justify-between">
                <time class="text-xs font-semibold text-slate-500" datetime="<%= day.iso8601 %>"><%= day.day %></time>
                <% if day == Date.current %>
                  <span class="rounded-full bg-emerald-600 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white">Today</span>
                <% end %>
              </header>

              <div class="grid gap-1.5">
                <% day_sessions.first(3).each do |training_session| %>
                  <%= link_to training_session_path(training_session), data: { turbo_frame: "session_popover", action: "click->session-popover#openAt", session_popover_trigger: true }, class: "grid rounded-md border border-emerald-200 bg-emerald-50 px-2 py-1.5 text-xs leading-tight text-emerald-900 transition hover:bg-emerald-100" do %>
                    <span class="font-semibold"><%= training_session.starts_at.strftime("%-I:%M %p") %></span>
                    <strong class="font-semibold"><%= training_session.title %></strong>
                  <% end %>
                <% end %>

                <% if day_sessions.size > 3 %>
                  <p class="text-xs font-medium text-slate-500">+<%= day_sessions.size - 3 %> more</p>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      </div>
    </div>
  </section>
<% end %>
