<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pickleball Training" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Pickleball Training">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <div data-controller="session-popover" data-action="click@window->session-popover#closeOnOutside keydown.esc@window->session-popover#close">
      <header class="sticky top-0 z-20 border-b border-slate-200/80 bg-slate-50/90 backdrop-blur">
        <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <%= link_to "Pickleball Performance Lab", root_path, class: "text-sm font-black tracking-wide text-slate-900 sm:text-base" %>
          <nav class="flex items-center gap-3 text-sm font-semibold text-slate-600">
            <%= link_to "Home", root_path, class: "rounded-full px-3 py-1.5 hover:bg-slate-200/70" %>
            <%= link_to "Calendar", calendar_path, class: "rounded-full px-3 py-1.5 hover:bg-slate-200/70" %>
            <%= link_to "FAQ", faq_path, class: "rounded-full px-3 py-1.5 hover:bg-slate-200/70" %>
            <%= link_to "Pricing", pricing_path, class: "rounded-full px-3 py-1.5 hover:bg-slate-200/70" %>
            <%= link_to "Contact", contact_path, class: "rounded-full px-3 py-1.5 hover:bg-slate-200/70" %>
            <%= link_to "About", about_path, class: "rounded-full px-3 py-1.5 hover:bg-slate-200/70" %>
          </nav>
        </div>
      </header>

      <%= yield %>

      <footer class="mt-12 border-t border-slate-200 bg-white">
        <div class="mx-auto grid w-full max-w-7xl gap-4 px-4 py-8 sm:px-6 lg:grid-cols-3 lg:px-8">
          <div>
            <p class="text-sm font-black tracking-wide text-slate-900">Pickleball Performance Lab</p>
            <p class="mt-1 text-sm text-slate-600">Coach Monsoud Zanaty</p>
            <p class="mt-1 text-sm text-slate-600">Private Court near Mt. Pleasent, DC</p>
          </div>

          <div class="text-sm text-slate-600">
            <div class="flex flex-wrap gap-3">
              <%= link_to "Calendar", calendar_path, class: "hover:text-slate-900" %>
              <%= link_to "FAQ", faq_path, class: "hover:text-slate-900" %>
              <%= link_to "Pricing", pricing_path, class: "hover:text-slate-900" %>
              <%= link_to "Contact", contact_path, class: "hover:text-slate-900" %>
            </div>
          </div>

          <div class="text-sm text-slate-600 lg:text-right">
            <p class="font-semibold text-slate-800">Training Hours</p>
            <p class="mt-1">Tue-Sun by appointment</p>
            <p class="mt-3 text-xs text-slate-500"><%= Time.current.year %> Pickleball Performance Lab</p>
          </div>
        </div>
      </footer>

      <section
        data-session-popover-target="panel"
        class="fixed z-40 hidden w-[min(360px,92vw)] rounded-2xl border border-slate-200 bg-white p-0 shadow-2xl"
      >
        <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
          <h2 class="text-lg font-black text-slate-900">Session Details</h2>
          <button
            type="button"
            data-action="click->session-popover#close"
            class="rounded-full border border-slate-300 px-3 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100"
          >
            Close
          </button>
        </div>

        <div class="max-h-[65vh] overflow-y-auto px-4 py-3">
          <%= turbo_frame_tag "session_popover", data: { action: "turbo:frame-load->session-popover#openFromFrame" } do %>
            <p class="rounded-xl border border-dashed border-slate-300 p-3 text-sm italic text-slate-500">Select a session to view details.</p>
          <% end %>
        </div>
      </section>
    </div>
  </body>
</html>
