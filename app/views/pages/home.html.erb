<% content_for :title, "Pickleball Performance Lab" %>

<main class="mx-auto grid w-full max-w-7xl gap-5 px-4 py-8 sm:px-6 lg:px-8">
  <section class="rounded-3xl border border-emerald-200/70 bg-gradient-to-br from-emerald-50 via-white to-amber-50 p-7 shadow-sm sm:p-9">
    <p class="text-xs font-bold uppercase tracking-[0.18em] text-emerald-700">Personal Training Platform</p>
    <h1 class="mt-2 text-3xl font-black leading-tight text-slate-900 sm:text-5xl">Train Smarter for Competitive Pickleball</h1>
    <p class="mt-3 max-w-3xl text-sm text-slate-600 sm:text-base">
      Build consistency in your dinks, confidence at the kitchen line, and better decision-making under pressure.
      Browse sessions and book your next rep-focused workout.
    </p>
    <div class="mt-5 flex flex-wrap gap-3">
      <%= link_to "Browse Calendar", calendar_path, class: "inline-flex items-center rounded-full bg-emerald-700 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-800" %>
      <%= link_to "View Today", calendar_path(month: Date.current.strftime("%Y-%m")), class: "inline-flex items-center rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100" %>
    </div>
  </section>

  <section class="grid gap-4">
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="mb-3 flex items-center justify-between gap-2">
        <h2 class="text-lg font-bold text-slate-900">Upcoming Sessions</h2>
        <%= link_to "Full calendar", calendar_path, class: "text-sm font-semibold text-slate-600 hover:text-slate-900" %>
      </div>

      <% if @next_sessions.any? %>
        <ul class="grid gap-3">
          <% @next_sessions.each do |training_session| %>
            <li class="flex flex-col gap-3 rounded-xl border border-slate-200 p-3 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="text-xs font-bold uppercase tracking-wide text-emerald-700"><%= training_session.starts_at.strftime("%a, %b %-d") %> at <%= training_session.starts_at.strftime("%-I:%M %p") %></p>
                <h3 class="mt-1 text-base font-bold text-slate-900"><%= training_session.title %></h3>
                <p class="text-sm text-slate-600"><%= training_session.coach.name %> - <%= training_session.skill_level %> - <%= training_session.location %></p>
              </div>
              <%= link_to "Details", training_session_path(training_session), data: { turbo_frame: "session_popover", action: "click->session-popover#openAt", session_popover_trigger: true }, class: "inline-flex items-center justify-center rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="rounded-xl border border-dashed border-slate-300 p-4 text-sm text-slate-500">No sessions yet. Seed data can be loaded with <code>bin/rails db:seed</code>.</p>
      <% end %>
    </article>
  </section>

  <section class="grid gap-4 lg:grid-cols-2">
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="mb-3 text-lg font-bold text-slate-900">Programs</h2>
      <ul class="grid gap-3">
        <% @programs.each do |program| %>
          <li class="rounded-xl border border-slate-200 p-3">
            <h3 class="text-base font-bold text-slate-900"><%= program.title %></h3>
            <p class="mt-1 text-sm font-semibold text-emerald-700"><%= program.level %> - <%= pluralize(program.duration_weeks, "week") %> - $<%= format("%.2f", program.price_dollars) %></p>
            <p class="mt-1 text-sm text-slate-600"><%= program.description %></p>
          </li>
        <% end %>
      </ul>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="mb-3 text-lg font-bold text-slate-900">Coaches</h2>
      <ul class="grid gap-3">
        <% @coaches.each do |coach| %>
          <li class="rounded-xl border border-slate-200 p-3">
            <h3 class="text-base font-bold text-slate-900"><%= coach.name %></h3>
            <p class="mt-1 text-sm font-semibold text-emerald-700"><%= coach.certification %> - <%= pluralize(coach.years_experience, "year") %> coaching</p>
            <p class="mt-1 text-sm text-slate-600"><%= coach.bio %></p>
          </li>
        <% end %>
      </ul>
    </article>
  </section>

</main>
