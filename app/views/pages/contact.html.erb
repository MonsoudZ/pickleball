<% content_for :title, "Contact" %>

<main class="mx-auto grid w-full max-w-4xl gap-5 px-4 py-8 sm:px-6 lg:px-8">
  <section class="rounded-3xl border border-emerald-200/70 bg-gradient-to-br from-emerald-50 via-white to-amber-50 p-7 shadow-sm sm:p-9">
    <p class="text-xs font-bold uppercase tracking-[0.18em] text-emerald-700">Contact</p>
    <h1 class="mt-2 text-3xl font-black leading-tight text-slate-900 sm:text-4xl">Book Your Private-Court Session</h1>
    <p class="mt-3 text-sm text-slate-700 sm:text-base">
      Share your age group, skill level, and goals. Sessions are held at the private court near Mt. Pleasent, DC.
    </p>
  </section>

  <% if flash[:notice].present? %>
    <div class="rounded-xl border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800"><%= flash[:notice] %></div>
  <% end %>

  <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <%= form_with model: @contact_message, url: contact_path, class: "grid gap-4" do |form| %>
      <% if @contact_message.errors.any? %>
        <div class="rounded-xl border border-rose-300 bg-rose-50 p-3 text-sm text-rose-700">
          <p class="font-semibold">Please fix the fields below:</p>
          <ul class="mt-1 list-disc pl-5">
            <% @contact_message.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <%= form.label :name, class: "mb-1 block text-sm font-semibold text-slate-700" %>
          <%= form.text_field :name, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none" %>
        </div>

        <div>
          <%= form.label :email, class: "mb-1 block text-sm font-semibold text-slate-700" %>
          <%= form.email_field :email, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none" %>
        </div>

        <div>
          <%= form.label :phone, class: "mb-1 block text-sm font-semibold text-slate-700" %>
          <%= form.telephone_field :phone, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none" %>
        </div>

        <div>
          <%= form.label :age_group, class: "mb-1 block text-sm font-semibold text-slate-700" %>
          <%= form.select :age_group, @age_group_options, { prompt: "Select age group" }, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none" %>
        </div>

        <div class="sm:col-span-2">
          <%= form.label :skill_level, class: "mb-1 block text-sm font-semibold text-slate-700" %>
          <%= form.select :skill_level, @skill_level_options, { prompt: "Select skill level" }, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none" %>
        </div>

        <div class="sm:col-span-2">
          <%= form.label :goals, "Primary goals", class: "mb-1 block text-sm font-semibold text-slate-700" %>
          <%= form.text_field :goals, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none" %>
        </div>

        <div class="sm:col-span-2">
          <%= form.label :message, class: "mb-1 block text-sm font-semibold text-slate-700" %>
          <%= form.text_area :message, rows: 5, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none" %>
        </div>
      </div>

      <div>
        <%= form.submit "Send Request", class: "inline-flex items-center rounded-full bg-emerald-700 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-800" %>
      </div>
    <% end %>
  </section>
</main>
